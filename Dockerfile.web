# Next.js 16 standalone runtime — multi-stage
# Build: docker build -f Dockerfile.web -t murmure-web .
# Run  : docker run -p 3000:3000 --env-file .env.production murmure-web

# --- 1) deps stage: install dependencies
FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy manifests + local workspaces referenced via file:
COPY package.json package-lock.json* ./
COPY packages ./packages
RUN npm ci --no-audit --no-fund

# --- 2) build stage: produce .next/standalone
FROM node:20-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
# NEXT_PUBLIC_* vars are inlined at build time — must be passed as ARG
ARG NEXT_PUBLIC_AMPLITUDE_API_KEY
ENV NEXT_PUBLIC_AMPLITUDE_API_KEY=$NEXT_PUBLIC_AMPLITUDE_API_KEY
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages ./packages
COPY . .
RUN if [ ! -f ../TourGuideApp/amplify/data/resource.ts ]; then \
      mkdir -p ../TourGuideApp/amplify/data && \
      cp src/types/amplify-schema-fallback.ts ../TourGuideApp/amplify/data/resource.ts; \
    fi
RUN npm run build

# --- 3) runner stage: minimal image
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs

# Standalone output bundles everything needed
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs
EXPOSE 3000
CMD ["node", "server.js"]
